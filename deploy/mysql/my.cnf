# MySQL 8 tuning for the CBT backend under exam-time concurrency.
# - Docker: mounted at /etc/mysql/conf.d/cbt.cnf by compose.yaml.
# - Bare-metal: copy into /etc/mysql/conf.d/ (Debian/Ubuntu) and restart mysql.
#
# Connection budget (the number that bites first): max_connections must cover
#   (PHP-FPM pm.max_children across ALL app nodes) + (queue workers) + headroom.
# With one node at pm.max_children=48 and 4 workers, 200 is comfortable; raise
# it (and buffer pool) for more nodes. See DEPLOYMENT.md.
[mysqld]
skip-name-resolve
max_connections = 200
thread_cache_size = 64
table_open_cache = 4000

# Size to ~60–70% of the DB box's RAM on a dedicated server. 2G shown for a
# small box; the hot tables (exam_sessions, student_answers, exam_codes) should
# live entirely in here.
innodb_buffer_pool_size = 2G
innodb_buffer_pool_instances = 4

# Throughput over absolute durability: =2 flushes the redo log once per second
# instead of per commit. Exam writes are autosaved and results are re-syncable,
# so this trade is appropriate and dramatically lifts write throughput. Use =1
# if your durability policy requires per-commit fsync.
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_redo_log_capacity = 1G
innodb_io_capacity = 2000

# Bigger in-memory temp tables before spilling to disk (results/exports do joins).
tmp_table_size = 64M
max_heap_table_size = 64M

character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci
