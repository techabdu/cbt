APP_NAME="CBT System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (MySQL 8) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cbt_online
DB_USERNAME=root
DB_PASSWORD=

# Cache, sessions, queue and locks run on Redis so MySQL is not the bottleneck
# under exam-time concurrency. Required for the 5k-concurrent target; the
# `database` driver still works for a tiny local run but does not scale.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Frontend SPA origin (CORS + Sanctum) ---
FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# --- Sanctum API token lifetime (minutes) — 8 hours ---
SANCTUM_TOKEN_EXPIRATION=480

# --- CBT online/offline sync ---
# Set IS_OFFLINE_SERVER=true on the CBT-center offline server.
IS_OFFLINE_SERVER=false
# LAN address of the offline server (online server pushes/pulls here). Blank on offline.
OFFLINE_SERVER_URL=http://192.168.1.10
# Shared secret for server-to-server sync. MUST match on both servers. Never commit.
SYNC_SECRET_KEY=
SYNC_TIMEOUT=30
SYNC_RETRIES=3
